{
  "id": "/Personal-Assistant/",
  "name": "Second Brain",
  "short_name": "Second Brain",
  "description": "Personal OS — kelola task, catatan, keuangan, dan jadwal kamu dalam satu tempat",

  "start_url": "/Personal-Assistant/",
  "scope": "/Personal-Assistant/",

  "display": "standalone",
  "display_override": [
    "tabbed",
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],

  "tab_strip": {
    "home_tab": {
      "scope_patterns": [
        { "pathname": "/" },
        { "pathname": "/Personal-Assistant/" }
      ]
    },
    "new_tab_button": {
      "url": "/Personal-Assistant/#tasks"
    }
  },


  "background_color": "#0e0e0e",
  "theme_color": "#4B6EFF",

  "orientation": "portrait",
  "lang": "id",
  "dir": "ltr",

  "categories": ["productivity", "utilities"],

  "icons": [
    {
      "src": "icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "icons/icon-192-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/icon-512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "screenshots": [
    {
      "src": "icons/screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Home Second Brain"
    },
    {
      "src": "icons/screenshot-wide.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard"
    }
  ],

  "shortcuts": [
    {
      "name": "Home",
      "short_name": "Home",
      "url": "/Personal-Assistant/#home",
      "icons": [
        {
          "src": "icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Tambah Task",
      "short_name": "Task",
      "url": "/Personal-Assistant/#tasks",
      "icons": [
        {
          "src": "icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],

  "share_target": {
    "action": "/Personal-Assistant/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "launch_handler": {
    "client_mode": "auto"
  },

  "file_handlers": [
    {
      "action": "/Personal-Assistant/",
      "accept": {
        "text/plain": [".txt"]
      }
    }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+secondbrain",
      "url": "/Personal-Assistant/?url=%s"
    }
  ],

  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://giri-fpxu.github.io/Personal-Assistant/",
      "id": "/Personal-Assistant/"
    }
  ],

  "prefer_related_applications": false,

  "iarc_rating_id": "e7b6c4f1-1234-5678-aaaa-bbbbccccdddd",

  "note_taking": {
    "new_note_url": "/Personal-Assistant/#notes"
  },

  "widgets": [
  {
    "name": "Quick Add",
    "short_name": "Add",
    "description": "Tambah task cepat",

    "tag": "quick-add",

    "type": "application/json",
    "display": "standalone",
    "multiple_instance": true,
    "ms_ac_template": "/Personal-Assistant/widgets/template.json",
    "data": "/Personal-Assistant/widgets/data.json",

    "screenshots": [
      {
        "src": "icons/screenshot1.png",
        "sizes": "600x400",
        "type": "image/png",
        "label": "Quick Add Widget"
      }
    ],

    "icons": [
      {
        "src": "icons/icon-192x192.png",
        "sizes": "192x192",
        "type": "image/png"
      }
    ]
  }
],
  "edge_side_panel": {
    "preferred_width": 400
  },

  "scope_extensions": [
    {
      "origin": "https://giri-fpxu.github.io",
      "scope": "/Personal-Assistant/"
    }
  ]
}